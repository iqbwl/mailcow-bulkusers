# Mailcow API configuration
# Base URL without trailing slash, e.g. https://mail.domain.com
MAILCOW_API_URL=https://mail.domain.com

# API key (read/write) from Admin -> Configuration -> API -> Add API key
MAILCOW_API_KEY=***CHANGE-ME***

# Delay between requests (seconds) - increase if the server is slow
REQUEST_DELAY=0.1

# Max number of users to process (0 = all). Use 5 for a quick test first.
LIMIT=0
